# Required environment variables for News Bot
# Copy this file to .env and fill in your values.
# See README.md for setup instructions for each service.

# Groq API (LLM summarization)
GROQ_API_KEY=

# Telegram Bot (message delivery)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Upstash Redis (state storage)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
